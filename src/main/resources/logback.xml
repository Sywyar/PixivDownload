<configuration>
    <conversionRule conversionWord="mdcColor"
                    class="top.sywyar.pixivdownload.logback.MdcColorConverter"/>

    <property name="console_pattern"
              value="%d{HH:mm:ss.SSS} %mdcColor(%-5level) %cyan([%thread]) %blue(%logger{36}) - %mdcColor(%msg) %n"/>
    <property name="file_pattern"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>

    <!-- 控制台 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${console_pattern}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!--
        ── 纯文本日志（log/） ──────────────────────────────────────────────────────
        append=true：logback 被 Spring Boot 重新初始化时续写而非截断，保留完整日志。
        GuiLauncher 在 logback 初始化前删除 latest.log，等效于覆盖写。
    -->
    <appender name="FILE_LATEST" class="ch.qos.logback.core.FileAppender">
        <file>log/latest.log</file>
        <append>true</append>
        <encoder>
            <pattern>${file_pattern}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="FILE_SESSION" class="ch.qos.logback.core.FileAppender">
        <file>log/pixiv-download_${LOG_TIMESTAMP:-startup}.log</file>
        <append>true</append>
        <encoder>
            <pattern>${file_pattern}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!--
        ── HTML 日志（log/html/） ──────────────────────────────────────────────────
        append=false：每次 logback 初始化都重新写完整 HTML 文件（含 <head> 和 CSS）。
        Spring Boot 重新初始化 logback 时会截断文件并重写头部；
        纯文本日志使用 append=true 保留了完整内容，HTML 日志侧重颜色可视性，
        丢失数条 Spring Boot 启动前的日志行可以接受。
    -->
    <appender name="HTML_LATEST" class="ch.qos.logback.core.FileAppender">
        <file>log/html/latest.html</file>
        <append>false</append>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="top.sywyar.pixivdownload.logback.HtmlLogLayout"/>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="HTML_SESSION" class="ch.qos.logback.core.FileAppender">
        <file>log/html/pixiv-download_${LOG_TIMESTAMP:-startup}.html</file>
        <append>false</append>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="top.sywyar.pixivdownload.logback.HtmlLogLayout"/>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_LATEST"/>
        <appender-ref ref="FILE_SESSION"/>
        <appender-ref ref="HTML_LATEST"/>
        <appender-ref ref="HTML_SESSION"/>
    </root>
</configuration>
